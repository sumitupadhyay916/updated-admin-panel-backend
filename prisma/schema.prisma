generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                 @id @default(cuid())
  email                    String                 @unique
  passwordHash             String
  name                     String
  role                     UserRole
  avatar                   String?
  phone                    String?
  status                   UserStatus             @default(active)
  permissions              String[]               @default([])
  createdById              String?
  adminId                  String?
  businessName             String?
  businessAddress          String?
  gstNumber                String?
  commissionRate           Float?
  totalEarnings            Float?                 @default(0)
  availableBalance         Float?                 @default(0)
  pendingBalance           Float?                 @default(0)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  activationToken          String?
  activationTokenExpires   DateTime?
  resetPasswordOtp         String?
  resetPasswordOtpExpires  DateTime?
  customerAbandonedCarts   AbandonedCart[]        @relation("CustomerAbandonedCarts")
  sellerAbandonedCarts     AbandonedCart[]        @relation("SellerAbandonedCarts")
  addresses                Address[]
  assignedCategories       AdminCategory[]        @relation("AdminCategories")
  categoriesCreated        Category[]             @relation("CategoryCreator")
  createdCoupons           Coupon[]               @relation("CouponCreatedBy")
  inventoryMoves           InventoryMovement[]    @relation("InventoryMovesByUser")
  reservations             InventoryReservation[]
  customerOrders           Order[]                @relation("CustomerOrders")
  orders                   Order[]                @relation("SellerOrders")
  timelineEvents           OrderTimeline[]        @relation("OrderTimelineByUser")
  processedPayouts         Payout[]               @relation("PayoutProcessedBy")
  payouts                  Payout[]               @relation("SellerPayouts")
  products                 Product[]              @relation("SellerProducts")
  queryResponses           QueryResponse[]        @relation("QueryResponseByUser")
  reviews                  Review[]               @relation("UserReviews")
  assignedSellerCategories SellerCategory[]       @relation("AdminSellerCategories")
  sellerCategories         SellerCategory[]       @relation("SellerCategories")
  sellerFaqs               SellerFAQ[]
  sellerPolicy             SellerPolicy?
  sellerStaff              Staff[]                @relation("SellerStaff")
  staffProfile             Staff?                 @relation("StaffUserProfile")
  updatedSupportPages      SupportPage[]          @relation("SupportPageUpdatedBy")
  admin                    User?                  @relation("AdminSellers", fields: [adminId], references: [id], onDelete: Restrict)
  sellers                  User[]                 @relation("AdminSellers")
  createdBy                User?                  @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers             User[]                 @relation("UserCreatedBy")

  @@index([role])
  @@index([status])
  @@index([createdById])
  @@index([adminId])
}

model Address {
  id                String      @id @default(cuid())
  userId            String
  type              AddressType @default(home)
  street            String
  city              String
  state             String
  pincode           String
  country           String      @default("India")
  isDefault         Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingForOrders  Order[]     @relation("OrderBillingAddress")
  shippingForOrders Order[]     @relation("OrderShippingAddress")

  @@index([userId])
  @@index([userId, isDefault])
}

model Category {
  id               Int              @id @default(autoincrement())
  cid              String           @unique @default(cuid())
  name             String
  slug             String?          @unique
  description      String?
  status           CategoryStatus   @default(active)
  noOfProducts     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  imageUrl         String?
  createdById      String?
  assignedAdmins   AdminCategory[]
  createdBy        User?            @relation("CategoryCreator", fields: [createdById], references: [id])
  products         Product[]
  sellerCategories SellerCategory[]
  subcategories    Subcategory[]

  @@index([status])
  @@index([name])
  @@index([cid])
  @@index([slug])
}

model Subcategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  categoryId  Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([slug])
}

model AdminCategory {
  id         String   @id @default(cuid())
  adminId    String
  categoryId Int
  assignedAt DateTime @default(now())
  admin      User     @relation("AdminCategories", fields: [adminId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([adminId, categoryId])
  @@index([adminId])
  @@index([categoryId])
}

model SellerCategory {
  id         String   @id @default(cuid())
  adminId    String
  sellerId   String
  categoryId Int
  assignedAt DateTime @default(now())
  admin      User     @relation("AdminSellerCategories", fields: [adminId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  seller     User     @relation("SellerCategories", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, categoryId])
  @@index([adminId])
  @@index([sellerId])
  @@index([categoryId])
}

model Product {
  id                 Int                    @id @default(autoincrement())
  pid                String                 @unique @default(cuid())
  name               String
  description        String?
  subcategorySlug    String?
  deity              Deity?
  material           Material?
  height             Float?
  weight             Float?
  handcrafted        Boolean                @default(false)
  occasion           Occasion[]             @default([])
  religionCategory   ReligionCategory?
  packagingType      PackagingType?
  fragile            Boolean                @default(false)
  price              Float
  comparePrice       Float?
  lowStockThreshold  Int                    @default(5)
  reviewCount        Int                    @default(0)
  isFeatured         Boolean                @default(false)
  tags               String[]               @default([])
  metadata           Json?
  sellerId           String
  categoryId         Int
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  stock              StockStatus            @default(available)
  subcategoryId      Int?
  stockQuantity      Int                    @default(0)
  averageRating      Float                  @default(0)
  hasVariants        Boolean                @default(false)
  status             ProductStatus          @default(active)
  inventoryMovements InventoryMovement[]
  reservations       InventoryReservation[]
  orderItems         OrderItem[]
  category           Category               @relation(fields: [categoryId], references: [id])
  seller             User                   @relation("SellerProducts", fields: [sellerId], references: [id])
  subcategory        Subcategory?           @relation(fields: [subcategoryId], references: [id])
  images             ProductImage[]
  options            ProductOption[]
  variants           ProductVariant[]
  reviews            Review[]               @relation("ProductReviews")

  @@index([sellerId])
  @@index([stock])
  @@index([isFeatured])
  @@index([categoryId])
  @@index([pid])
  @@index([subcategorySlug])
  @@index([subcategoryId])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId Int
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, url])
  @@index([productId, sortOrder])
}

model ProductOption {
  id         String               @id @default(cuid())
  productId  Int
  name       String
  isActive   Boolean              @default(true)
  isRequired Boolean              @default(false)
  meta       Json?
  scope      OptionScope          @default(variant)
  sortOrder  Int                  @default(0)
  uiType     OptionUiType?
  product    Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values     ProductOptionValue[]

  @@unique([productId, name])
  @@index([productId])
}

model ProductOptionValue {
  id        String               @id @default(cuid())
  optionId  String
  value     String
  imageUrl  String?
  meta      Json?
  sortOrder Int                  @default(0)
  sortValue Int                  @default(0)
  swatchHex String?
  valueKey  String?
  option    ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants  VariantOptionValue[]

  @@unique([optionId, value])
  @@unique([optionId, valueKey])
  @@index([optionId])
}

model ProductVariant {
  id                 String                 @id @default(cuid())
  productId          Int
  price              Float
  comparePrice       Float?
  stock              Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  sku                String?
  color              String?
  quality            String?
  size               String?
  colorHex           String?
  mrp                Float?                 @default(0)
  stockQuantity      Int                    @default(0)
  description        String?                @db.Text
  isActive           Boolean                @default(true)
  inventoryMovements InventoryMovement[]
  reservations       InventoryReservation[]
  orderItems         OrderItem[]
  product            Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  specifications     ProductVariantSpec[]
  images             VariantImage[]
  optionValues       VariantOptionValue[]

  @@unique([productId, sku])
  @@index([productId])
  @@index([sku])
}

model VariantOptionValue {
  variantId     String
  optionValueId String
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([optionValueId])
}

model VariantImage {
  id        String         @id @default(cuid())
  variantId String
  url       String
  sortOrder Int            @default(0)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Review {
  id           String   @id @default(cuid())
  productId    Int
  userId       String
  rating       Int
  title        String?
  comment      String
  isVerified   Boolean  @default(false)
  isApproved   Boolean  @default(true)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  user         User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  productId     Int
  type          InventoryMovementType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String
  notes         String?
  createdById   String
  createdAt     DateTime              @default(now())
  variantId     String?
  createdBy     User                  @relation("InventoryMovesByUser", fields: [createdById], references: [id])
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       ProductVariant?       @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([createdById])
  @@index([createdAt])
}

model Order {
  id                 String            @id @default(cuid())
  orderNumber        String            @unique
  customerId         String
  sellerId           String?
  shippingAddressId  String
  billingAddressId   String
  subtotal           Float
  taxAmount          Float             @default(0)
  shippingAmount     Float             @default(0)
  discountAmount     Float             @default(0)
  totalAmount        Float
  couponCode         String?
  orderStatus        OrderStatus       @default(pending)
  paymentStatus      PaymentStatus     @default(pending)
  paymentMethod      String
  fulfillmentStatus  FulfillmentStatus @default(unfulfilled)
  trackingNumber     String?
  carrier            String?
  notes              String?
  internalNotes      String?
  sellerEarnings     Float             @default(0)
  platformCommission Float             @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  billingAddress     Address           @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])
  customer           User              @relation("CustomerOrders", fields: [customerId], references: [id])
  seller             User?             @relation("SellerOrders", fields: [sellerId], references: [id])
  shippingAddress    Address           @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  items              OrderItem[]
  timeline           OrderTimeline[]

  @@index([customerId])
  @@index([sellerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  productId     Int
  productName   String
  productImage  String
  deity         Deity
  material      Material
  height        Float
  weight        Float
  packagingType PackagingType
  fragile       Boolean
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  sellerId      String
  sellerName    String
  color         String?
  size          String?
  variantId     String?
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([sellerId])
}

model OrderTimeline {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  description String
  createdById String
  createdAt   DateTime    @default(now())
  createdBy   User        @relation("OrderTimelineByUser", fields: [createdById], references: [id])
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Payout {
  id                  String       @id @default(cuid())
  sellerId            String
  amount              Float
  commissionDeduction Float        @default(0)
  finalAmount         Float
  status              PayoutStatus @default(pending)
  paymentMethod       String
  accountDetails      String
  transactionId       String?
  requestedAt         DateTime     @default(now())
  processedAt         DateTime?
  processedById       String?
  notes               String?
  processedBy         User?        @relation("PayoutProcessedBy", fields: [processedById], references: [id])
  seller              User         @relation("SellerPayouts", fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
  @@index([requestedAt])
}

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique
  description       String?
  discountType      DiscountType
  discountValue     Float
  minOrderAmount    Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usageCount        Int          @default(0)
  startDate         DateTime
  endDate           DateTime
  applicableTo      ApplicableTo @default(all)
  sellerIds         String[]     @default([])
  productIds        String[]     @default([])
  isActive          Boolean      @default(true)
  createdById       String
  createdAt         DateTime     @default(now())
  categoryIds       Int[]        @default([])
  isFreeShipping    Boolean      @default(false)
  limitPerUser      Int?
  maxSpend          Float?
  title             String       @default("")
  updatedAt         DateTime     @updatedAt
  createdBy         User         @relation("CouponCreatedBy", fields: [createdById], references: [id])

  @@index([isActive])
  @@index([startDate, endDate])
}

model ContactQuery {
  id         String          @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  category   String
  status     QueryStatus     @default(open)
  priority   QueryPriority   @default(medium)
  assignedTo String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  responses  QueryResponse[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model QueryResponse {
  id              String       @id @default(cuid())
  queryId         String
  message         String
  respondedById   String
  respondedByName String
  createdAt       DateTime     @default(now())
  query           ContactQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  respondedBy     User         @relation("QueryResponseByUser", fields: [respondedById], references: [id])

  @@index([queryId])
  @@index([createdAt])
}

model SupportPage {
  id          String          @id @default(cuid())
  slug        SupportPageSlug @unique
  title       String
  content     String
  lastUpdated DateTime        @default(now())
  updatedById String
  updatedBy   User            @relation("SupportPageUpdatedBy", fields: [updatedById], references: [id])
}

model FAQ {
  id       String  @id @default(cuid())
  question String
  answer   String
  category String
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@index([category])
  @@index([isActive])
  @@index([order])
}

model PlatformSettings {
  id                    String   @id @default(cuid())
  platformName          String   @default("Innorade")
  platformLogo          String?
  supportEmail          String   @default("support@innorade.com")
  supportPhone          String   @default("+91-0000000000")
  defaultCommissionRate Float    @default(15)
  minPayoutAmount       Float    @default(1000)
  currency              String   @default("INR")
  timezone              String   @default("Asia/Kolkata")
  updatedAt             DateTime @updatedAt
}

model AbandonedCart {
  id             String              @id @default(cuid())
  cartNumber     String              @unique @default(cuid())
  customerId     String?
  customerName   String
  customerEmail  String
  customerPhone  String?
  sellerId       String
  cartValue      Float               @default(0)
  itemCount      Int                 @default(0)
  status         AbandonedCartStatus @default(abandoned)
  emailStatus    EmailStatus         @default(not_sent)
  recoveredAt    DateTime?
  reminderSentAt DateTime?
  couponCode     String?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  customer       User?               @relation("CustomerAbandonedCarts", fields: [customerId], references: [id])
  seller         User                @relation("SellerAbandonedCarts", fields: [sellerId], references: [id], onDelete: Cascade)
  items          AbandonedCartItem[]

  @@index([sellerId])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
}

model AbandonedCartItem {
  id           String        @id @default(cuid())
  cartId       String
  productId    String?
  productName  String
  productImage String?
  quantity     Int           @default(1)
  unitPrice    Float
  totalPrice   Float
  cart         AbandonedCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

model SellerPolicy {
  id              String   @id @default(cuid())
  sellerId        String   @unique
  privacyPolicy   String   @default("")
  termsConditions String   @default("")
  updatedAt       DateTime @updatedAt
  seller          User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model SellerFAQ {
  id        String   @id @default(cuid())
  sellerId  String
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model Staff {
  id          String   @id @default(cuid())
  userId      String   @unique
  sellerId    String
  role        String
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seller      User     @relation("SellerStaff", fields: [sellerId], references: [id], onDelete: Cascade)
  user        User     @relation("StaffUserProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model InventoryReservation {
  id        String            @id @default(cuid())
  productId Int
  variantId String?
  userId    String
  quantity  Int
  status    ReservationStatus @default(active)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProductVariant?   @relation(fields: [variantId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([variantId])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, productId, variantId])
}

model ProductVariantSpec {
  id        String         @id @default(cuid())
  variantId String
  label     String
  value     String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

enum UserRole {
  super_admin
  admin
  seller
  consumer
  staff
}

enum UserStatus {
  active
  suspended
  inactive
}

enum CategoryStatus {
  active
  inactive
}

enum ProductStatus {
  active
  inactive
  pending
  rejected
}

enum Deity {
  Ganesh
  Krishna
  Shiva
  Durga
  Lakshmi
  Saraswati
  Hanuman
  Ram
  Vishnu
  Kali
  Other
}

enum Material {
  Brass
  Marble
  Resin
  Clay
  Silver
  Wood
  Gold
  Panchdhatu
  Copper
  Other
}

enum ReligionCategory {
  Hindu
  Buddhist
  Jain
  Sikh
  Universal
}

enum PackagingType {
  Box
  Velvet_Box
  Wooden_Case
  Gift_Wrap
  Standard
}

enum Occasion {
  Diwali
  Puja
  Wedding
  Festival
  Housewarming
  Birthday
  Anniversary
  Corporate
  Daily_Worship
  Tuesday_Special
  Navratri
  Ganesh_Chaturthi
  Vasant_Panchami
}

enum InventoryMovementType {
  in
  out
  adjustment
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum FulfillmentStatus {
  unfulfilled
  partial
  fulfilled
}

enum PayoutStatus {
  pending
  processing
  completed
  rejected
}

enum DiscountType {
  percentage
  fixed
}

enum ApplicableTo {
  all
  specific_sellers
  specific_products
}

enum QueryStatus {
  open
  in_progress
  resolved
  closed
}

enum QueryPriority {
  low
  medium
  high
  urgent
}

enum AddressType {
  home
  work
  other
}

enum SupportPageSlug {
  help_center
  faqs
  privacy_policy
  terms_conditions
}

enum SpecDataType {
  text
  int
  float
  boolean
  enum
  json
}

enum SpecScope {
  product
  variant
}

enum SpecUiType {
  input
  textarea
  number
  select
  multiselect
  boolean
  dimension
}

enum OptionScope {
  variant
  product
}

enum OptionUiType {
  buttons
  dropdown
  swatch
  image
  text
}

enum StockStatus {
  available
  unavailable
}

enum AbandonedCartStatus {
  abandoned
  recovered
  expired
}

enum EmailStatus {
  not_sent
  sent
  opened
}

enum ReservationStatus {
  active
  expired
  converted
}
